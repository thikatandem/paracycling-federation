extends ../../_layout/default

block view

  .container-fluid

    .row
      .col-12

        .card.mb-4

          .card-header.d-flex.justify-content-between.align-items-center

            strong Staff Certifications

            button.btn.btn-primary(
              type='button'
              id='btnAddCertification'
            )
              i.fa.fa-plus.me-2
              | Add Certification

          .card-body

            div.d-none.text-center.mb-3(
              id='certificationLoading'
            )
              .spinner-border.text-primary

            .row.mb-3

              .col-md-4

                input.form-control(
                  type='text'
                  id='searchCertification'
                  placeholder='Search Certifications'
                )

            .table-responsive

              table.table.table-striped.table-hover

                thead

                  tr

                    th Staff

                    th Certification

                    th Issuing Body

                    th Issue Date

                    th Expiry Date

                    th Actions

                tbody#certificationsTableBody

            .row.mt-3

              .col-md-6

                button.btn.btn-secondary(
                  type='button'
                  id='btnRefreshCertifications'
                )
                  | Refresh

              .col-md-6.text-end

                button.btn.btn-outline-primary.me-2(
                  type='button'
                  id='btnPreviousCertificationPage'
                )
                  | Previous

                span#certificationPaginationInfo.mx-2
                  | Page 1

                button.btn.btn-outline-primary(
                  type='button'
                  id='btnNextCertificationPage'
                )
                  | Next

  .modal.fade(
    id='certificationModal'
    tabindex='-1'
    aria-hidden='true'
  )

    .modal-dialog.modal-lg

      .modal-content

        .modal-header

          h5.modal-title#certificationModalTitle
            | Certification

          button.btn-close(
            type='button'
            data-coreui-dismiss='modal'
          )

        .modal-body

          input(
            type='hidden'
            id='certificationId'
          )

          .row.g-3

            .col-md-12

              label.form-label Staff

              select.form-select(
                id='certificationStaffId'
              )

            .col-md-6

              label.form-label Certification Name

              input.form-control(
                id='certificationName'
              )

            .col-md-6

              label.form-label Issuing Body

              input.form-control(
                id='issuingBody'
              )

            .col-md-6

              label.form-label Issue Date

              input.form-control(
                type='date'
                id='issueDate'
              )

            .col-md-6

              label.form-label Expiry Date

              input.form-control(
                type='date'
                id='certificationExpiry'
              )

          .mt-3.text-danger(
            id='certificationFormError'
          )

        .modal-footer

          button.btn.btn-secondary(
            type='button'
            data-coreui-dismiss='modal'
          )
            | Cancel

          button.btn.btn-success(
            type='button'
            id='btnSaveCertification'
          )
            | Save Certification

  .modal.fade(
    id='deleteCertificationModal'
    tabindex='-1'
    aria-hidden='true'
  )

    .modal-dialog

      .modal-content

        .modal-header

          h5.modal-title
            | Delete Certification

          button.btn-close(
            type='button'
            data-coreui-dismiss='modal'
          )

        .modal-body

          p
            | Are you sure you want to delete this certification?

          input(
            type='hidden'
            id='deleteCertificationId'
          )

        .modal-footer

          button.btn.btn-secondary(
            type='button'
            data-coreui-dismiss='modal'
          )
            | Cancel

          button.btn.btn-danger(
            type='button'
            id='btnConfirmDeleteCertification'
          )
            | Delete

block append pageScripts

  script(
    type='module'
    src='js/staff.js'
  )