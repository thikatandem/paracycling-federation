extends ../../_layout/default

block view

  .container-fluid

    .row
      .col-12

        .card.mb-4

          .card-header.d-flex.justify-content-between.align-items-center

            strong Staff Reviews

            button.btn.btn-primary(
              type='button'
              id='btnAddReview'
            )
              i.fa.fa-plus.me-2
              | Add Review

          .card-body

            div.d-none.text-center.mb-3(
              id='reviewLoading'
            )
              .spinner-border.text-primary

            .row.mb-3

              .col-md-4

                input.form-control(
                  type='text'
                  id='searchReview'
                  placeholder='Search Reviews'
                )

            .table-responsive

              table.table.table-striped.table-hover

                thead

                  tr

                    th Staff

                    th Review Date

                    th Reviewer

                    th Score

                    th Comments

                    th Actions

                tbody#reviewsTableBody

            .row.mt-3

              .col-md-6

                button.btn.btn-secondary(
                  type='button'
                  id='btnRefreshReviews'
                )
                  | Refresh

              .col-md-6.text-end

                button.btn.btn-outline-primary.me-2(
                  type='button'
                  id='btnPreviousReviewPage'
                )
                  | Previous

                span#reviewPaginationInfo.mx-2
                  | Page 1

                button.btn.btn-outline-primary(
                  type='button'
                  id='btnNextReviewPage'
                )
                  | Next

  .modal.fade(
    id='reviewModal'
    tabindex='-1'
    aria-hidden='true'
  )

    .modal-dialog.modal-lg

      .modal-content

        .modal-header

          h5.modal-title#reviewModalTitle
            | Review

          button.btn-close(
            type='button'
            data-coreui-dismiss='modal'
          )

        .modal-body

          input(
            type='hidden'
            id='reviewId'
          )

          .row.g-3

            .col-md-12

              label.form-label Staff

              select.form-select(
                id='reviewStaffId'
              )

            .col-md-4

              label.form-label Review Date

              input.form-control(
                type='date'
                id='reviewDate'
              )

            .col-md-4

              label.form-label Reviewer

              input.form-control(
                id='reviewer'
              )

            .col-md-4

              label.form-label Score

              input.form-control(
                type='number'
                step='0.01'
                id='reviewScore'
              )

            .col-md-12

              label.form-label Comments

              textarea.form-control(
                rows='4'
                id='reviewComments'
              )

          .mt-3.text-danger(
            id='reviewFormError'
          )

        .modal-footer

          button.btn.btn-secondary(
            type='button'
            data-coreui-dismiss='modal'
          )
            | Cancel

          button.btn.btn-success(
            type='button'
            id='btnSaveReview'
          )
            | Save Review

  .modal.fade(
    id='deleteReviewModal'
    tabindex='-1'
    aria-hidden='true'
  )

    .modal-dialog

      .modal-content

        .modal-header

          h5.modal-title
            | Delete Review

          button.btn-close(
            type='button'
            data-coreui-dismiss='modal'
          )

        .modal-body

          p
            | Are you sure you want to delete this review?

          input(
            type='hidden'
            id='deleteReviewId'
          )

        .modal-footer

          button.btn.btn-secondary(
            type='button'
            data-coreui-dismiss='modal'
          )
            | Cancel

          button.btn.btn-danger(
            type='button'
            id='btnConfirmDeleteReview'
          )
            | Delete

block append pageScripts

  script(
    type='module'
    src='js/staff.js'
  )