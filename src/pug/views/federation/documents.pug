extends ../../_layout/default

block view

  .container-fluid

    .row
      .col-12

        .card.mb-4

          .card-header.d-flex.justify-content-between.align-items-center

            strong Documents

            button.btn.btn-primary(
              type='button'
              id='btnAddDocument'
            )
              i.fa.fa-plus.me-2
              | Upload Document

          .card-body

            div.d-none.text-center.mb-3(
              id='documentsLoading'
            )
              .spinner-border.text-primary

            .row.mb-3

              .col-md-4
                input.form-control(
                  type='text'
                  id='searchDocument'
                  placeholder='Search Documents'
                )

            .table-responsive

              table.table.table-striped.table-hover

                thead

                  tr
                    th Document Type
                    th File Name
                    th Uploaded At
                    th File Size
                    th MIME Type
                    th Actions

                tbody#documentsTableBody

            .row.mt-3

              .col-md-6

                button.btn.btn-secondary(
                  type='button'
                  id='btnRefreshDocuments'
                )
                  | Refresh

              .col-md-6.text-end

                button.btn.btn-outline-primary.me-2(
                  type='button'
                  id='btnPreviousDocumentPage'
                )
                  | Previous

                span#documentsPaginationInfo.mx-2
                  | Page 1

                button.btn.btn-outline-primary(
                  type='button'
                  id='btnNextDocumentPage'
                )
                  | Next

  .modal.fade(
    id='documentModal'
    tabindex='-1'
    aria-hidden='true'
  )

    .modal-dialog.modal-xl

      .modal-content

        .modal-header

          h5.modal-title#documentModalTitle
            | Document

          button.btn-close(
            type='button'
            data-coreui-dismiss='modal'
          )

        .modal-body

          input(
            type='hidden'
            id='documentId'
          )

          .row.g-3

            .col-md-4
              label.form-label Document Type
              input.form-control(
                id='documentType'
              )

            .col-md-4
              label.form-label File Name
              input.form-control(
                id='fileName'
              )

            .col-md-4
              label.form-label File URL
              input.form-control(
                id='fileUrl'
              )

            .col-md-4
              label.form-label Athlete
              select.form-select(
                id='athleteId'
              )

            .col-md-4
              label.form-label Team
              select.form-select(
                id='teamId'
              )

            .col-md-4
              label.form-label Event
              select.form-select(
                id='eventId'
              )

            .col-md-4
              label.form-label Medical Record
              select.form-select(
                id='medicalId'
              )

            .col-md-4
              label.form-label Travel Request
              select.form-select(
                id='travelId'
              )

            .col-md-4
              label.form-label Equipment
              select.form-select(
                id='equipmentId'
              )

            .col-md-4
              label.form-label File Size
              input.form-control(
                type='number'
                id='fileSize'
              )

            .col-md-4
              label.form-label MIME Type
              input.form-control(
                id='mimeType'
              )

            .col-md-4
              label.form-label Storage Bucket
              input.form-control(
                id='storageBucket'
              )

          .mt-3.text-danger(
            id='documentFormError'
          )

        .modal-footer

          button.btn.btn-secondary(
            type='button'
            data-coreui-dismiss='modal'
          )
            | Cancel

          button.btn.btn-success(
            type='button'
            id='btnSaveDocument'
          )
            | Save Document

  .modal.fade(
    id='deleteDocumentModal'
    tabindex='-1'
    aria-hidden='true'
  )

    .modal-dialog

      .modal-content

        .modal-header

          h5.modal-title
            | Delete Document

          button.btn-close(
            type='button'
            data-coreui-dismiss='modal'
          )

        .modal-body

          p
            | Are you sure you want to delete this document?

          input(
            type='hidden'
            id='deleteDocumentId'
          )

        .modal-footer

          button.btn.btn-secondary(
            type='button'
            data-coreui-dismiss='modal'
          )
            | Cancel

          button.btn.btn-danger(
            type='button'
            id='btnConfirmDeleteDocument'
          )
            | Delete Document
append pageScripts
  script(src='js/documents.js')
