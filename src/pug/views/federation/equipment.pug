extends ../../_layout/default

block view

  .container-fluid

    .row
      .col-12

        .card.mb-4

          .card-header.d-flex.justify-content-between.align-items-center

            strong Equipment

            button.btn.btn-primary(
              type='button'
              id='btnAddEquipment'
            )
              i.fa.fa-plus.me-2
              | Add Equipment

          .card-body

            div.d-none.text-center.mb-3(
              id='equipmentLoading'
            )
              .spinner-border.text-primary

            .row.mb-3

              .col-md-4
                input.form-control(
                  type='text'
                  id='searchEquipment'
                  placeholder='Search Equipment'
                )

            .table-responsive

              table.table.table-striped.table-hover

                thead

                  tr
                    th Equipment Code
                    th Asset Tag
                    th Type
                    th Serial Number
                    th Purchase Date
                    th Status
                    th Actions

                tbody#equipmentTableBody

            .row.mt-3

              .col-md-6

                button.btn.btn-secondary(
                  type='button'
                  id='btnRefreshEquipment'
                )
                  | Refresh

              .col-md-6.text-end

                button.btn.btn-outline-primary.me-2(
                  type='button'
                  id='btnPreviousEquipmentPage'
                )
                  | Previous

                span#equipmentPaginationInfo.mx-2
                  | Page 1

                button.btn.btn-outline-primary(
                  type='button'
                  id='btnNextEquipmentPage'
                )
                  | Next

  .modal.fade(
    id='equipmentModal'
    tabindex='-1'
    aria-hidden='true'
  )

    .modal-dialog.modal-xl

      .modal-content

        .modal-header

          h5.modal-title#equipmentModalTitle
            | Equipment

          button.btn-close(
            type='button'
            data-coreui-dismiss='modal'
          )

        .modal-body

          input(
            type='hidden'
            id='equipmentId'
          )

          .row.g-3

            .col-md-3
              label.form-label Equipment Code
              input.form-control(
                id='equipmentCode'
                readonly
              )

            .col-md-3
              label.form-label Asset Tag
              input.form-control(
                id='assetTag'
              )

            .col-md-3
              label.form-label Equipment Type
              select.form-select(
                id='equipmentTypeId'
              )

            .col-md-3
              label.form-label Status
              select.form-select(
                id='statusId'
              )

            .col-md-4
              label.form-label Serial Number
              input.form-control(
                id='serialNumber'
              )

            .col-md-4
              label.form-label Purchase Date
              input.form-control(
                type='date'
                id='purchaseDate'
              )

            .col-md-4
              label.form-label Purchase Cost
              input.form-control(
                type='number'
                step='0.01'
                id='purchaseCost'
              )

            .col-md-12
              label.form-label Description
              textarea.form-control(
                rows='4'
                id='description'
              )

          .mt-3.text-danger(
            id='equipmentFormError'
          )

        .modal-footer

          button.btn.btn-secondary(
            type='button'
            data-coreui-dismiss='modal'
          )
            | Cancel

          button.btn.btn-success(
            type='button'
            id='btnSaveEquipment'
          )
            | Save Equipment

  .modal.fade(
    id='deleteEquipmentModal'
    tabindex='-1'
    aria-hidden='true'
  )

    .modal-dialog

      .modal-content

        .modal-header

          h5.modal-title
            | Delete Equipment

          button.btn-close(
            type='button'
            data-coreui-dismiss='modal'
          )

        .modal-body

          p
            | Are you sure you want to delete this equipment?

          input(
            type='hidden'
            id='deleteEquipmentId'
          )

        .modal-footer

          button.btn.btn-secondary(
            type='button'
            data-coreui-dismiss='modal'
          )
            | Cancel

          button.btn.btn-danger(
            type='button'
            id='btnConfirmDeleteEquipment'
          )
            | Delete Equipment
append pageScripts
  script(src='js/equipment.js')