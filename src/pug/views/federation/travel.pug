extends ../../_layout/default

block view

  .container-fluid

    .row
      .col-12

        .card.mb-4

          .card-header.d-flex.justify-content-between.align-items-center

            strong Travel

            button.btn.btn-primary(
              type='button'
              id='btnAddTravel'
            )
              i.fa.fa-plus.me-2
              | Add Travel Request

          .card-body

            div.d-none.text-center.mb-3(
              id='travelLoading'
            )
              .spinner-border.text-primary

            .row.mb-3

              .col-md-4
                input.form-control(
                  type='text'
                  id='searchTravel'
                  placeholder='Search Travel Requests'
                )

            .table-responsive

              table.table.table-striped.table-hover

                thead

                  tr
                    th Athlete
                    th Team
                    th Event
                    th Country
                    th Departure
                    th Return
                    th Status
                    th Actions

                tbody#travelTableBody

            .row.mt-3

              .col-md-6

                button.btn.btn-secondary(
                  type='button'
                  id='btnRefreshTravel'
                )
                  | Refresh

              .col-md-6.text-end

                button.btn.btn-outline-primary.me-2(
                  type='button'
                  id='btnPreviousTravelPage'
                )
                  | Previous

                span#travelPaginationInfo.mx-2
                  | Page 1

                button.btn.btn-outline-primary(
                  type='button'
                  id='btnNextTravelPage'
                )
                  | Next

  .modal.fade(
    id='travelModal'
    tabindex='-1'
    aria-hidden='true'
  )

    .modal-dialog.modal-xl

      .modal-content

        .modal-header

          h5.modal-title#travelModalTitle
            | Travel Request

          button.btn-close(
            type='button'
            data-coreui-dismiss='modal'
          )

        .modal-body

          input(
            type='hidden'
            id='travelId'
          )

          .row.g-3

            .col-md-4
              label.form-label Athlete
              select.form-select(
                id='athleteId'
              )

            .col-md-4
              label.form-label Team
              select.form-select(
                id='teamId'
              )

            .col-md-4
              label.form-label Event
              select.form-select(
                id='eventId'
              )

            .col-md-4
              label.form-label Destination Country
              select.form-select(
                id='destinationCountryId'
              )

            .col-md-4
              label.form-label Destination City
              input.form-control(
                id='destinationCity'
              )

            .col-md-4
              label.form-label Status
              select.form-select(
                id='statusId'
              )

            .col-md-4
              label.form-label Departure Date
              input.form-control(
                type='date'
                id='departureDate'
              )

            .col-md-4
              label.form-label Return Date
              input.form-control(
                type='date'
                id='returnDate'
              )

            .col-md-12
              label.form-label Purpose
              textarea.form-control(
                rows='4'
                id='purpose'
              )

          .mt-3.text-danger(
            id='travelFormError'
          )

        .modal-footer

          button.btn.btn-secondary(
            type='button'
            data-coreui-dismiss='modal'
          )
            | Cancel

          button.btn.btn-success(
            type='button'
            id='btnSaveTravel'
          )
            | Save Travel Request

  .modal.fade(
    id='deleteTravelModal'
    tabindex='-1'
    aria-hidden='true'
  )

    .modal-dialog

      .modal-content

        .modal-header

          h5.modal-title
            | Delete Travel Request

          button.btn-close(
            type='button'
            data-coreui-dismiss='modal'
          )

        .modal-body

          p
            | Are you sure you want to delete this travel request?

          input(
            type='hidden'
            id='deleteTravelId'
          )

        .modal-footer

          button.btn.btn-secondary(
            type='button'
            data-coreui-dismiss='modal'
          )
            | Cancel

          button.btn.btn-danger(
            type='button'
            id='btnConfirmDeleteTravel'
          )
            | Delete Travel Request
append pageScripts
  script(src='js/travel_requests.js')