extends ../../_layout/default

block view

  .container-fluid

    .row
      .col-12

        .card.mb-4

          .card-header.d-flex.justify-content-between.align-items-center

            strong Event Master

            button.btn.btn-primary(
              type='button'
              id='btnNewEvent'
            )
              i.fa.fa-plus.me-2
              | New Event Master

          .card-body

            .row.mb-3

              .col-md-4

                input.form-control(
                  type='text'
                  id='searchEvent'
                  placeholder='Search Event Masters'
                )

            .table-responsive

              table.table.table-striped.table-hover

                thead

                  tr
                    th Event Name
                    th Event Category
                    th Event Type
                    th Status
                    th Actions

                tbody#eventTableBody

            .row.mt-3

              .col-md-6
                small.text-muted#paginationInfo

              .col-md-6.text-end
                ul.pagination.justify-content-end.mb-0#paginationContainer

  .modal.fade(
    id='eventModal'
    tabindex='-1'
    aria-hidden='true'
  )

    .modal-dialog

      .modal-content

        .modal-header

          h5.modal-title Event Master

          button.btn-close(
            type='button'
            data-coreui-dismiss='modal'
          )

        .modal-body

          input(
            type='hidden'
            id='eventId'
          )

          .mb-3

            label.form-label Event Name

            input.form-control(
              id='eventName'
              list='eventNameSuggestions'
              placeholder='Enter Event Name'
            )

            datalist#eventNameSuggestions

          .mb-3

            label.form-label Event Category

            select.form-select(
              id='eventCategoryId'
            )
              option(value='') Select Event Category

          .mb-3

            label.form-label Event Type

            select.form-select(
              id='eventTypeId'
            )
              option(value='') Select Event Type

          .mb-3.d-none(
            id='eventStatusContainer'
          )

            label.form-label Status

            select.form-select(
              id='eventStatusId'
            )
              option(value='') Select Status

          .alert.alert-danger.d-none(
            id='eventError'
          )

        .modal-footer

          button.btn.btn-secondary(
            type='button'
            data-coreui-dismiss='modal'
          )
            | Close

          button.btn.btn-primary(
            type='button'
            id='btnSaveEvent'
          )
            | Save Event

  .modal.fade(
    id='programModal'
    tabindex='-1'
    aria-hidden='true'
  )

    .modal-dialog.modal-lg

      .modal-content

        .modal-header

          h5.modal-title Event Programs

          button.btn-close(
            type='button'
            data-coreui-dismiss='modal'
          )

        .modal-body

          input(
            type='hidden'
            id='programEventId'
          )

          .row

            .col-md-6.mb-3

              label.form-label Event Name

              input.form-control(
                id='programEventName'
                readonly
              )

            .col-md-6.mb-3

              label.form-label Event Type

              input.form-control(
                id='programEventType'
                readonly
              )

          .row

            .col-md-8.mb-3

              label.form-label Program Name

              input.form-control(
                id='programName'
                placeholder='Example: 3 Day'
              )

            .col-md-4.mb-3.d-flex.align-items-end

              button.btn.btn-success.w-100(
                type='button'
                id='btnSaveProgram'
              )
                | Add Program

          .table-responsive

            table.table.table-striped

              thead

                tr
                  th Program Name
                  th Actions

              tbody#programTableBody

append pageScripts

  script(src='js/events-master.js')