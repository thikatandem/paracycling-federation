extends ../../_layout/default

block view

  .container-fluid

    .row
      .col-12

        .card.mb-4

          .card-header.d-flex.justify-content-between.align-items-center

            strong Teams

            button.btn.btn-primary(
              type='button'
              id='btnAddTeam'
            )
              i.fa.fa-plus.me-2
              | Add Team

          .card-body

            div.d-none.text-center.mb-3(
              id='teamLoading'
            )
              .spinner-border.text-primary

            .row.mb-3

              .col-md-4
                input.form-control(
                  type='text'
                  id='searchTeam'
                  placeholder='Search Teams'
                )

            .table-responsive

              table.table.table-striped.table-hover

                thead

                  tr
                    th Team Code
                    th Team Name
                    th Team Nick Name
                    th Team Members
                    th Pilot
                    th Stoker
                    th Formed Date
                    th Status
                    th Actions

                tbody#teamsTableBody

            .row.mt-3

              .col-md-6

                button.btn.btn-secondary(
                  type='button'
                  id='btnRefreshTeams'
                )
                  | Refresh

              .col-md-6.text-end

                button.btn.btn-outline-primary.me-2(
                  type='button'
                  id='btnPreviousTeamPage'
                )
                  | Previous

                span#teamPaginationInfo.mx-2
                  | Page 1

                button.btn.btn-outline-primary(
                  type='button'
                  id='btnNextTeamPage'
                )
                  | Next

  .modal.fade(
    id='teamModal'
    tabindex='-1'
    aria-hidden='true'
  )

    .modal-dialog.modal-xl

      .modal-content

        .modal-header

          h5.modal-title#teamModalTitle
            | Team

          button.btn-close(
            type='button'
            data-coreui-dismiss='modal'
          )

        .modal-body

          input(
            type='hidden'
            id='teamId'
          )

          .row.g-3

            .col-md-4
              label.form-label Team Code
              input.form-control(
                id='teamCode'
                readonly
              )

            .col-md-4
              label.form-label Team Name
              input.form-control(
                type='text'
                id='teamName'
                placeholder='Enter Official Team Name'
              )

            .col-md-4
              label.form-label Team Nickname
              input.form-control(
                id='teamNickname'
              )

            .col-md-4
              label.form-label Status
              select.form-select(
                id='teamStatus'
              )
                option(value='Active' selected) Active
                option(value='Inactive') Inactive
                option(value='Suspended') Suspended
                option(value='Disbanded') Disbanded

            .col-md-6
              label.form-label Pilot Athlete
              select.form-select(
                id='pilotAthleteId'
              )

            .col-md-6
              label.form-label Stoker Athlete
              select.form-select(
                id='stokerAthleteId'
              )

            .col-md-6
              label.form-label Formed Date
              input.form-control(
                type='date'
                id='formedDate'
              )

            .col-md-6
              label.form-label Dissolved Date
              input.form-control(
                type='date'
                id='dissolvedDate'
              )

          .mt-3.text-danger(
            id='teamFormError'
          )

        .modal-footer

          button.btn.btn-secondary(
            type='button'
            data-coreui-dismiss='modal'
          )
            | Cancel

          button.btn.btn-success(
            type='button'
            id='btnSaveTeam'
          )
            | Save Team

  .modal.fade(
    id='deleteTeamModal'
    tabindex='-1'
    aria-hidden='true'
  )

    .modal-dialog

      .modal-content

        .modal-header

          h5.modal-title
            | Delete Team

          button.btn-close(
            type='button'
            data-coreui-dismiss='modal'
          )

        .modal-body

          p
            | Are you sure you want to delete this team?

          input(
            type='hidden'
            id='deleteTeamId'
          )

        .modal-footer

          button.btn.btn-secondary(
            type='button'
            data-coreui-dismiss='modal'
          )
            | Cancel

          button.btn.btn-danger(
            type='button'
            id='btnConfirmDeleteTeam'
          )
            | Delete Team

append pageScripts
  script(src='js/teams.js')