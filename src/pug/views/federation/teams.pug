extends ../../_layout/default

block view

  .container-fluid

    .row
      .col-12

        .card.mb-4

          .card-header.d-flex.justify-content-between.align-items-center

            strong Teams

            button.btn.btn-primary(
              type='button'
              id='btnAddTeam'
            )
              i.fa.fa-plus.me-2
              | Add Team

          .card-body

            div.d-none.text-center.mb-3(
              id='teamLoading'
            )
              .spinner-border.text-primary

            .row.mb-3

              .col-md-4
                input.form-control(
                  type='text'
                  id='searchTeam'
                  placeholder='Search Team Name, Code, Pilot or Stoker'
                )

            .table-responsive

              table.table.table-striped.table-hover

                thead

                  tr
                    th Team Code
                    th Team Name
                    th Team Nickname
                    th Current Pilot
                    th Current Stoker
                    th Effective Date
                    th Status
                    th Actions

                tbody#teamsTableBody

            .row.mt-3

              .col-md-6

                button.btn.btn-secondary(
                  type='button'
                  id='btnRefreshTeams'
                )
                  | Refresh

              .col-md-6.text-end

                button.btn.btn-outline-primary.me-2(
                  type='button'
                  id='btnPreviousTeamPage'
                )
                  | Previous

                span#teamPaginationInfo.mx-2
                  | Page 1

                button.btn.btn-outline-primary(
                  type='button'
                  id='btnNextTeamPage'
                )
                  | Next

  // TEAM CREATE / EDIT MODAL

  .modal.fade(
    id='teamModal'
    tabindex='-1'
    aria-hidden='true'
  )

    .modal-dialog.modal-xl

      .modal-content

        .modal-header

          h5.modal-title#teamModalTitle
            | Team

          button.btn-close(
            type='button'
            data-coreui-dismiss='modal'
          )

        .modal-body

          input(
            type='hidden'
            id='teamId'
          )

          .row.g-3

            .col-md-3

              label.form-label Team Code

              input.form-control(
                id='teamCode'
                readonly
              )

            .col-md-5

              label.form-label Team Name

              input.form-control(
                type='text'
                id='teamName'
                placeholder='Official Team Name'
              )

            .col-md-4

              label.form-label Team Nickname

              input.form-control(
                id='teamNickname'
                placeholder='Optional Nickname'
              )

            .col-md-4

              label.form-label Team Status

              select.form-select(
                id='teamStatus'
              )
                option(
                  value='Active'
                  selected
                ) Active

                option(
                  value='Inactive'
                ) Inactive

                option(
                  value='Suspended'
                ) Suspended

                option(
                  value='Disbanded'
                ) Disbanded

            .col-md-4

              label.form-label Effective Date

              input.form-control(
                type='date'
                id='effectiveDate'
              )

            .col-md-4

              label.form-label Change Reason

              input.form-control(
                type='text'
                id='changeReason'
                placeholder='Initial Formation / Reassignment'
              )

            .col-md-6

              label.form-label Pilot Athlete

              select.form-select(
                id='pilotAthleteId'
              )

            .col-md-6

              label.form-label Stoker Athlete

              select.form-select(
                id='stokerAthleteId'
              )

          .mt-4

            h6.mb-3
              | Current Pairing

            .table-responsive

              table.table.table-bordered

                thead

                  tr
                    th Role
                    th Athlete
                    th Active Since

                tbody#currentPairingBody

          .mt-4

            h6.mb-3
              | Team Pairing History

            .table-responsive

              table.table.table-striped

                thead

                  tr
                    th Role
                    th Athlete
                    th Start Date
                    th End Date
                    th Active
                    th Change Reason

                tbody#teamHistoryBody

          .mt-3.text-danger(
            id='teamFormError'
          )

        .modal-footer

          button.btn.btn-secondary(
            type='button'
            data-coreui-dismiss='modal'
          )
            | Cancel

          button.btn.btn-success(
            type='button'
            id='btnSaveTeam'
          )
            | Save Team

  // DELETE MODAL

  .modal.fade(
    id='deleteTeamModal'
    tabindex='-1'
    aria-hidden='true'
  )

    .modal-dialog

      .modal-content

        .modal-header

          h5.modal-title
            | Delete Team

          button.btn-close(
            type='button'
            data-coreui-dismiss='modal'
          )

        .modal-body

          p
            | Are you sure you want to delete this team?

          input(
            type='hidden'
            id='deleteTeamId'
          )

        .modal-footer

          button.btn.btn-secondary(
            type='button'
            data-coreui-dismiss='modal'
          )
            | Cancel

          button.btn.btn-danger(
            type='button'
            id='btnConfirmDeleteTeam'
          )
            | Delete Team

append pageScripts

  script(src='js/teams.js')