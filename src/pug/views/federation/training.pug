extends ../../_layout/default

block view

  .container-fluid

    .row

      .col-12

        .card.mb-4

          .card-header.d-flex.justify-content-between.align-items-center

            strong Training Log

            button.btn.btn-primary(
              type='button'
              id='btnAddTraining'
            )
              i.fa.fa-plus.me-2
              | Add Training

          .card-body

            div.d-none.text-center.mb-3(
              id='trainingLoading'
            )
              .spinner-border.text-primary

            .row.mb-3

              .col-md-4

                input.form-control(
                  type='text'
                  id='searchTraining'
                  placeholder='Search Event, Program, Team or Session'
                )

            .table-responsive

              table.table.table-striped.table-hover

                thead

                  tr

                    th Date
                    th Event
                    th Program
                    th Team
                    th Session
                    th Distance
                    th Duration
                    th Avg Speed
                    th Actions

                tbody#trainingTableBody

            .row.mt-3

              .col-md-6

                button.btn.btn-secondary(
                  type='button'
                  id='btnRefreshTraining'
                )
                  Refresh

              .col-md-6.text-end

                button.btn.btn-outline-primary.me-2(
                  type='button'
                  id='btnPreviousPage'
                )
                  Previous

                span#paginationInfo.mx-2
                  Page 1

                button.btn.btn-outline-primary(
                  type='button'
                  id='btnNextPage'
                )
                  Next

  .modal.fade(
    id='trainingModal'
    tabindex='-1'
    aria-hidden='true'
  )

    .modal-dialog.modal-xl

      .modal-content

        .modal-header

          h5.modal-title
            Training Log

          button.btn-close(
            type='button'
            data-coreui-dismiss='modal'
          )

        .modal-body

          input(
            type='hidden'
            id='trainingId'
          )

          .row.g-3

            .col-md-4

              label.form-label Training Event

              select.form-select(
                id='eventId'
              )

            .col-md-4

              label.form-label Program

              select.form-select(
                id='programId'
              )

                option(value='') Select Program

            .col-md-4

              label.form-label Participant Team

              select.form-select(
                id='participantId'
              )

                option(value='') Select Participant

            .col-md-3

              label.form-label Training Date

              input.form-control(
                type='date'
                id='trainingDate'
              )

            .col-md-3

              label.form-label Training Week

              input.form-control(
                type='number'
                id='trainingWeek'
              )

            .col-md-3

              label.form-label Training Day

              input.form-control(
                type='number'
                id='trainingDay'
              )

            .col-md-3

              label.form-label Session Type

              input.form-control(
                id='sessionType'
              )

            .col-md-3

              label.form-label Start Time

              input.form-control(
                type='time'
                id='startTime'
              )

            .col-md-3

              label.form-label End Time

              input.form-control(
                type='time'
                id='endTime'
              )

            .col-md-3

              label.form-label Duration (Minutes)

              input.form-control(
                type='number'
                id='durationMinutes'
                readonly
              )

            .col-md-3

              label.form-label Distance (KM)

              input.form-control(
                type='number'
                step='0.01'
                id='distanceKm'
              )

            .col-md-4

              label.form-label Average Speed

              input.form-control(
                type='number'
                id='avgSpeedKmh'
                readonly
              )

            .col-md-4

              label.form-label Indoor Session

              select.form-select(
                id='indoorSession'
              )

                option(value='false') No
                option(value='true') Yes

            .col-md-4

              label.form-label Attendance

              select.form-select(
                id='attendance'
              )

               option(value='true') Present
               option(value='false') Absent

            .col-md-12

              label.form-label Notes

              textarea.form-control(
                rows='3'
                id='notes'
              )

          .mt-3.text-danger(
            id='trainingFormError'
          )

        .modal-footer

          button.btn.btn-secondary(
            type='button'
            data-coreui-dismiss='modal'
          )
            Cancel

          button.btn.btn-success(
            type='button'
            id='btnSaveTraining'
          )
            Save Training

  .modal.fade(
    id='deleteTrainingModal'
    tabindex='-1'
    aria-hidden='true'
  )

    .modal-dialog

      .modal-content

        .modal-header

          h5.modal-title
            Delete Training Log

          button.btn-close(
            type='button'
            data-coreui-dismiss='modal'
          )

        .modal-body

          p
            Are you sure you want to delete this training record?

          input(
            type='hidden'
            id='deleteTrainingId'
          )

        .modal-footer

          button.btn.btn-secondary(
            type='button'
            data-coreui-dismiss='modal'
          )
            Cancel

          button.btn.btn-danger(
            type='button'
            id='btnConfirmDeleteTraining'
          )
            Delete Training

append pageScripts

  script(src='js/training-log.js')