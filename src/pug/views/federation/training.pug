extends ../../_layout/default

block view

  .container-fluid

    .row

      .col-12

        .card.mb-4

          .card-header.d-flex.justify-content-between.align-items-center

            strong Training Log

            button.btn.btn-primary(
              type='button'
              id='btnAddTraining'
            )
              i.fa.fa-plus.me-2
              | Add Training

          .card-body

            div.d-none.text-center.mb-3(
              id='trainingLoading'
            )
              .spinner-border.text-primary

            .row.mb-3

              .col-md-4

                input.form-control(
                  type='text'
                  id='searchTraining'
                  placeholder='Search Team, Session Type or Notes'
                )

            .table-responsive

              table.table.table-striped.table-hover

                thead

                  tr

                    th Training Date
                    th Team
                    th Session Type
                    th Distance (KM)
                    th Duration (Minutes)
                    th Attendance
                    th Notes
                    th Actions

                tbody#trainingTableBody

            .row.mt-3

              .col-md-6

                button.btn.btn-secondary(
                  type='button'
                  id='btnRefreshTraining'
                )
                  | Refresh

              .col-md-6.text-end

                button.btn.btn-outline-primary.me-2(
                  type='button'
                  id='btnPreviousPage'
                )
                  | Previous

                span#paginationInfo.mx-2
                  | Page 1

                button.btn.btn-outline-primary(
                  type='button'
                  id='btnNextPage'
                )
                  | Next

  .modal.fade(
    id='trainingModal'
    tabindex='-1'
    aria-hidden='true'
  )

    .modal-dialog.modal-lg

      .modal-content

        .modal-header

          h5.modal-title
            | Training Log

          button.btn-close(
            type='button'
            data-coreui-dismiss='modal'
          )

        .modal-body

          input(
            type='hidden'
            id='trainingId'
          )

          .row.g-3

            .col-md-4

              label.form-label Training Date

              input.form-control(
                type='date'
                id='trainingDate'
              )

            .col-md-4

              label.form-label Team

              select.form-select(
                id='teamId'
              )

            .col-md-4

              label.form-label Session Type

              input.form-control(
                id='sessionType'
                placeholder='Road, Track, Recovery, Sprint'
              )

            .col-md-4

              label.form-label Distance (KM)

              input.form-control(
                type='number'
                min='0'
                step='0.01'
                id='distanceKm'
              )

            .col-md-4

              label.form-label Duration (Minutes)

              input.form-control(
                type='number'
                min='0'
                id='durationMinutes'
              )

            .col-md-4

              label.form-label Attendance

              select.form-select(
                id='attendance'
              )

                option(value='true')
                  | Present

                option(value='false')
                  | Absent

            .col-md-12

              label.form-label Notes

              textarea.form-control(
                rows='3'
                id='notes'
              )

          .mt-3.text-danger(
            id='trainingFormError'
          )

        .modal-footer

          button.btn.btn-secondary(
            type='button'
            data-coreui-dismiss='modal'
          )
            | Cancel

          button.btn.btn-success(
            type='button'
            id='btnSaveTraining'
          )
            | Save Training

  .modal.fade(
    id='deleteTrainingModal'
    tabindex='-1'
    aria-hidden='true'
  )

    .modal-dialog

      .modal-content

        .modal-header

          h5.modal-title
            | Delete Training Log

          button.btn-close(
            type='button'
            data-coreui-dismiss='modal'
          )

        .modal-body

          p
            | Are you sure you want to delete this training record?

          input(
            type='hidden'
            id='deleteTrainingId'
          )

        .modal-footer

          button.btn.btn-secondary(
            type='button'
            data-coreui-dismiss='modal'
          )
            | Cancel

          button.btn.btn-danger(
            type='button'
            id='btnConfirmDeleteTraining'
          )
            | Delete Training

append pageScripts

  script(src='js/training-log.js')