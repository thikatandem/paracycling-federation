extends ../../_layout/default

block view

  .container-fluid

    .row

      .col-12

        .card.mb-4

          .card-header.d-flex.justify-content-between.align-items-center

            strong Performance

            button.btn.btn-primary(
              type='button'
              id='btnAddPerformance'
            )
              i.fa.fa-plus.me-2
              | Add Performance

          .card-body

            div.d-none.text-center.mb-3(
              id='performanceLoading'
            )
              .spinner-border.text-primary

            .row.mb-3

              .col-md-4

                input.form-control(
                  type='text'
                  id='searchPerformance'
                  placeholder='Search Team'
                )

            .table-responsive

              table.table.table-striped.table-hover

                thead

                  tr
                    th Date
                    th Team
                    th Distance (KM)
                    th Duration (Min)
                    th Speed
                    th Avg HR
                    th Max HR
                    th Cadence
                    th Power
                    th RPE
                    th Actions

                tbody#performanceTableBody

            .row.mt-3

              .col-md-6

                button.btn.btn-secondary(
                  type='button'
                  id='btnRefreshPerformance'
                )
                  | Refresh

              .col-md-6.text-end

                button.btn.btn-outline-primary.me-2(
                  type='button'
                  id='btnPreviousPage'
                )
                  | Previous

                span#paginationInfo.mx-2
                  | Page 1

                button.btn.btn-outline-primary(
                  type='button'
                  id='btnNextPage'
                )
                  | Next

  .modal.fade(
    id='performanceModal'
    tabindex='-1'
    aria-hidden='true'
  )

    .modal-dialog.modal-xl

      .modal-content

        .modal-header

          h5.modal-title#performanceModalTitle
            | Performance

          button.btn-close(
            type='button'
            data-coreui-dismiss='modal'
          )

        .modal-body

          input(
            type='hidden'
            id='performanceId'
          )

          .row.g-3

            .col-md-4

              label.form-label Performance Date

              input.form-control(
                type='date'
                id='performanceDate'
              )

            .col-md-4

              label.form-label Team

              select.form-select(
                id='teamId'
              )

            .col-md-4

              label.form-label Distance KM

              input.form-control(
                type='number'
                step='0.01'
                id='distanceKm'
              )

            .col-md-4

              label.form-label Duration Minutes

              input.form-control(
                type='number'
                id='durationMinutes'
              )

            .col-md-4

              label.form-label Average HR

              input.form-control(
                type='number'
                id='avgHr'
              )

            .col-md-4

              label.form-label Max HR

              input.form-control(
                type='number'
                id='maxHr'
              )

            .col-md-4

              label.form-label Cadence

              input.form-control(
                type='number'
                id='cadence'
              )

            .col-md-4

              label.form-label Power Watts

              input.form-control(
                type='number'
                id='powerWatts'
              )

            .col-md-4

              label.form-label RPE (1-10)

              input.form-control(
                type='number'
                min='1'
                max='10'
                id='rpe'
              )

            .col-md-4

              label.form-label Speed KM/H

              input.form-control(
                id='speedKmh'
                readonly
              )

          .mt-3.text-danger(
            id='performanceFormError'
          )

        .modal-footer

          button.btn.btn-secondary(
            type='button'
            data-coreui-dismiss='modal'
          )
            | Cancel

          button.btn.btn-success(
            type='button'
            id='btnSavePerformance'
          )
            | Save Performance

  .modal.fade(
    id='deletePerformanceModal'
    tabindex='-1'
    aria-hidden='true'
  )

    .modal-dialog

      .modal-content

        .modal-header

          h5.modal-title
            | Delete Performance

          button.btn-close(
            type='button'
            data-coreui-dismiss='modal'
          )

        .modal-body

          p
            | Are you sure you want to delete this performance record?

          input(
            type='hidden'
            id='deletePerformanceId'
          )

        .modal-footer

          button.btn.btn-secondary(
            type='button'
            data-coreui-dismiss='modal'
          )
            | Cancel

          button.btn.btn-danger(
            type='button'
            id='btnConfirmDeletePerformance'
          )
            | Delete

append pageScripts

  script(src='js/performance.js')