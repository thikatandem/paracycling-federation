extends ../../_layout/default

block view

  .container-fluid

    .row
      .col-12

        .card.mb-4

          .card-header.d-flex.justify-content-between.align-items-center

            strong Staff Assignments

            button.btn.btn-primary(
              type='button'
              id='btnAddAssignment'
            )
              i.fa.fa-plus.me-2
              | Add Assignment

          .card-body

            div.d-none.text-center.mb-3(
              id='assignmentLoading'
            )
              .spinner-border.text-primary

            .row.mb-3

              .col-md-4

                input.form-control(
                  type='text'
                  id='searchAssignment'
                  placeholder='Search Assignments'
                )

            .table-responsive

              table.table.table-striped.table-hover

                thead

                  tr

                    th Staff

                    th Role

                    th Team

                    th Start Date

                    th End Date

                    th Active

                    th Reason

                    th Actions

                tbody#assignmentsTableBody

            .row.mt-3

              .col-md-6

                button.btn.btn-secondary(
                  type='button'
                  id='btnRefreshAssignments'
                )
                  | Refresh

              .col-md-6.text-end

                button.btn.btn-outline-primary.me-2(
                  type='button'
                  id='btnPreviousAssignmentPage'
                )
                  | Previous

                span#assignmentPaginationInfo.mx-2
                  | Page 1

                button.btn.btn-outline-primary(
                  type='button'
                  id='btnNextAssignmentPage'
                )
                  | Next

  .modal.fade(
    id='assignmentModal'
    tabindex='-1'
    aria-hidden='true'
  )

    .modal-dialog.modal-lg

      .modal-content

        .modal-header

          h5.modal-title#assignmentModalTitle
            | Assignment

          button.btn-close(
            type='button'
            data-coreui-dismiss='modal'
          )

        .modal-body

          input(
            type='hidden'
            id='assignmentId'
          )

          .row.g-3

            .col-md-6

              label.form-label Staff

              select.form-select(
                id='assignmentStaffId'
              )

            .col-md-6

              label.form-label Role

              select.form-select(
                id='assignmentRoleId'
              )

            .col-md-6

              label.form-label Team

              select.form-select(
                id='assignmentTeamId'
              )

            .col-md-3

              label.form-label Start Date

              input.form-control(
                type='date'
                id='assignmentStartDate'
              )

            .col-md-3

              label.form-label End Date

              input.form-control(
                type='date'
                id='assignmentEndDate'
              )

            .col-md-3

              label.form-label Active

              select.form-select(
                id='assignmentIsActive'
              )

                option(
                  value='true'
                )
                  Active

                option(
                  value='false'
                )
                  Inactive

            .col-md-12

              label.form-label Assignment Reason

              textarea.form-control(
                rows='4'
                id='assignmentReason'
              )

          .mt-3.text-danger(
            id='assignmentFormError'
          )

        .modal-footer

          button.btn.btn-secondary(
            type='button'
            data-coreui-dismiss='modal'
          )
            | Cancel

          button.btn.btn-success(
            type='button'
            id='btnSaveAssignment'
          )
            | Save Assignment

  .modal.fade(
    id='deleteAssignmentModal'
    tabindex='-1'
    aria-hidden='true'
  )

    .modal-dialog

      .modal-content

        .modal-header

          h5.modal-title
            | Delete Assignment

          button.btn-close(
            type='button'
            data-coreui-dismiss='modal'
          )

        .modal-body

          p
            | Are you sure you want to delete this assignment?

          input(
            type='hidden'
            id='deleteAssignmentId'
          )

        .modal-footer

          button.btn.btn-secondary(
            type='button'
            data-coreui-dismiss='modal'
          )
            | Cancel

          button.btn.btn-danger(
            type='button'
            id='btnConfirmDeleteAssignment'
          )
            | Delete

block append pageScripts

  script(
    type='module'
    src='js/staff.js'
  )