extends ../../_layout/default

block view

  .container-fluid

    .row
      .col-12

        .card.mb-4

          .card-header.d-flex.justify-content-between.align-items-center

            strong Medical

            button.btn.btn-primary(
              type='button'
              id='btnAddMedical'
            )
              i.fa.fa-plus.me-2
              | Add Medical Record

          .card-body

            div.d-none.text-center.mb-3(
              id='medicalLoading'
            )
              .spinner-border.text-primary

            .row.mb-3

              .col-md-4
                input.form-control(
                  type='text'
                  id='searchMedical'
                  placeholder='Search Medical Records'
                )

            .table-responsive

              table.table.table-striped.table-hover

                thead

                  tr
                    th Athlete
                    th Examination Date
                    th Doctor
                    th Clearance Status
                    th Next Review
                    th Actions

                tbody#medicalTableBody

            .row.mt-3

              .col-md-6

                button.btn.btn-secondary(
                  type='button'
                  id='btnRefreshMedical'
                )
                  | Refresh

              .col-md-6.text-end

                button.btn.btn-outline-primary.me-2(
                  type='button'
                  id='btnPreviousMedicalPage'
                )
                  | Previous

                span#medicalPaginationInfo.mx-2
                  | Page 1

                button.btn.btn-outline-primary(
                  type='button'
                  id='btnNextMedicalPage'
                )
                  | Next

  .modal.fade(
    id='medicalModal'
    tabindex='-1'
    aria-hidden='true'
  )

    .modal-dialog.modal-xl

      .modal-content

        .modal-header

          h5.modal-title#medicalModalTitle
            | Medical Record

          button.btn-close(
            type='button'
            data-coreui-dismiss='modal'
          )

        .modal-body

          input(
            type='hidden'
            id='medicalId'
          )

          .row.g-3

            .col-md-4
              label.form-label Athlete
              select.form-select(
                id='athleteId'
              )

            .col-md-4
              label.form-label Examination Date
              input.form-control(
                type='date'
                id='examinationDate'
              )

            .col-md-4
              label.form-label Doctor Name
              input.form-control(
                id='doctorName'
              )

            .col-md-4
              label.form-label Clearance Status
              input.form-control(
                id='clearanceStatus'
              )

            .col-md-4
              label.form-label Next Review Date
              input.form-control(
                type='date'
                id='nextReviewDate'
              )

            .col-md-12
              label.form-label Diagnosis
              textarea.form-control(
                rows='3'
                id='diagnosis'
              )

            .col-md-12
              label.form-label Treatment
              textarea.form-control(
                rows='3'
                id='treatment'
              )

            .col-md-12
              label.form-label Restrictions
              textarea.form-control(
                rows='3'
                id='restrictions'
              )

            .col-md-12
              label.form-label Notes
              textarea.form-control(
                rows='4'
                id='notes'
              )

          .mt-3.text-danger(
            id='medicalFormError'
          )

        .modal-footer

          button.btn.btn-secondary(
            type='button'
            data-coreui-dismiss='modal'
          )
            | Cancel

          button.btn.btn-success(
            type='button'
            id='btnSaveMedical'
          )
            | Save Medical Record

  .modal.fade(
    id='deleteMedicalModal'
    tabindex='-1'
    aria-hidden='true'
  )

    .modal-dialog

      .modal-content

        .modal-header

          h5.modal-title
            | Delete Medical Record

          button.btn-close(
            type='button'
            data-coreui-dismiss='modal'
          )

        .modal-body

          p
            | Are you sure you want to delete this medical record?

          input(
            type='hidden'
            id='deleteMedicalId'
          )

        .modal-footer

          button.btn.btn-secondary(
            type='button'
            data-coreui-dismiss='modal'
          )
            | Cancel

          button.btn.btn-danger(
            type='button'
            id='btnConfirmDeleteMedical'
          )
            | Delete Medical Record
append pageScripts
  script(src='js/medical_records.js')