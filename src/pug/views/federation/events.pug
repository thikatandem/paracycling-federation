extends ../../_layout/default

block view

  .container-fluid

    .row

      .col-12

        .card.mb-4

          .card-header.d-flex.justify-content-between.align-items-center

            strong Events

            button.btn.btn-primary(
              type='button'
              id='btnAddEvent'
            )
              i.fa.fa-plus.me-2
              | Add Event

          .card-body

            div.d-none.text-center.mb-3(
              id='eventLoading'
            )
              .spinner-border.text-primary

            .row.mb-3

              .col-md-4

                input.form-control(
                  type='text'
                  id='searchEvent'
                  placeholder='Search Events'
                )

            .table-responsive

              table.table.table-striped.table-hover

                thead

                  tr

                    
                    th Event Name
                    th Category
                    th Country
                    th County
                    th Sub County
                    th Town
                    th City
                    th Organizer
                    th Event Type
                    th Sponsors
                    th Start
                    th End
                    th Status
                    th Actions

                tbody#eventsTableBody

            .row.mt-3

              .col-md-6

                button.btn.btn-secondary(
                  type='button'
                  id='btnRefreshEvents'
                )
                  | Refresh

              .col-md-6.text-end

                button.btn.btn-outline-primary.me-2(
                  type='button'
                  id='btnPreviousPage'
                )
                  | Previous

                span#paginationInfo.mx-2
                  | Page 1

                button.btn.btn-outline-primary(
                  type='button'
                  id='btnNextPage'
                )
                  | Next

  .modal.fade(
    id='eventModal'
    tabindex='-1'
    aria-hidden='true'
  )

    .modal-dialog.modal-xl

      .modal-content

        .modal-header

          h5.modal-title#eventModalTitle
            | Event

          button.btn-close(
            type='button'
            data-coreui-dismiss='modal'
          )

        .modal-body

          input(
            type='hidden'
            id='eventId'
          )

          .row.g-3

            .col-md-3

              input(
                type='hidden'
                id='eventCode'
              )

            .col-md-5

              label.form-label Event Name

              input.form-control(
                id='eventName'
              )

            .col-md-4

              label.form-label Country

              select.form-select(
                id='countryId'
              )

            .col-md-4

              label.form-label County

              select.form-select(
                id='countyId'
             )

            .col-md-4

              label.form-label Sub County

              select.form-select(
                id='subcountyId'
              )

            .col-md-4

              label.form-label Town

              select.form-select(
                id='townId'
             )

            .col-md-4

              label.form-label City

              input.form-control(
                id='city'
              )

            .col-md-4

              label.form-label Organizer

              input.form-control(
                id='organizer'
              )

            .col-md-4

              label.form-label Event Type

              select.form-select(
                id='eventTypeId'
              )

            .col-md-4

              label.form-label Event Category

              select.form-select(
                id='eventCategory'
              )

                option(value='') Select Category
                option(value='TRAINING') Training
                option(value='COMPETITION') Competition

            .col-md-12

              label.form-label Sponsors

              select.form-select(
                id='sponsorIds'
                multiple
              )

            .col-md-3

              label.form-label Start Date

              input.form-control(
                type='date'
                id='startDate'
              )

            .col-md-3

              label.form-label Start Time

              input.form-control(
                type='time'
                id='startTime'
              )

            .col-md-3

              label.form-label End Date

              input.form-control(
                type='date'
                id='endDate'
              )

            .col-md-3

              label.form-label End Time

              input.form-control(
                type='time'
                id='endTime'
              )

            .col-md-4

              label.form-label Status

              input.form-control(
                id='eventStatus'
                readonly
                value='Automatic'
              )

          .mt-3.text-danger(
            id='eventFormError'
          )

        .modal-footer

          button.btn.btn-secondary(
            type='button'
            data-coreui-dismiss='modal'
          )
            | Cancel

          button.btn.btn-success(
            type='button'
            id='btnSaveEvent'
          )
            | Save Event

  .modal.fade(
    id='deleteEventModal'
    tabindex='-1'
    aria-hidden='true'
  )

    .modal-dialog

      .modal-content

        .modal-header

          h5.modal-title
            | Delete Event

          button.btn-close(
            type='button'
            data-coreui-dismiss='modal'
          )

        .modal-body

          p
            | Are you sure you want to delete this event?

          input(
            type='hidden'
            id='deleteEventId'
          )

        .modal-footer

          button.btn.btn-secondary(
            type='button'
            data-coreui-dismiss='modal'
          )
            | Cancel

          button.btn.btn-danger(
            type='button'
            id='btnConfirmDeleteEvent'
          )
            | Delete Event

  .modal.fade(
    id='programModal'
    tabindex='-1'
    aria-hidden='true'
  )

    .modal-dialog.modal-lg

      .modal-content

        .modal-header

          h5.modal-title
            | Event Programs

          button.btn-close(
            type='button'
            data-coreui-dismiss='modal'
          )

        .modal-body

          input(
            type='hidden'
            id='programEventId'
          )

          h6.mb-3(
            id='programEventName'
          )

          .row.g-3.mb-4

            .col-md-4

              label.form-label Program Name

              input.form-control(
                id='programName'
              )

            .col-md-3

              label.form-label Type

              select.form-select(
                id='programType'
              )

                option(value='') Select Type
                option(value='TRAINING') Training
                option(value='COMPETITION') Competition

            .col-md-2

              label.form-label Days

              input.form-control(
                type='number'
                id='daysPerWeek'
              )

            .col-md-3.d-flex.align-items-end

              button.btn.btn-success.w-100(
                type='button'
                id='btnSaveProgram'
              )
                Add Program

          .table-responsive

            table.table.table-striped

              thead

                tr

                  th Program
                  th Type
                  th Days
                  th Active
                  th Actions

              tbody#programTableBody

append pageScripts

  script(src='js/events.js')