extends ../../_layout/default

block view

  .container-fluid

    .row
      .col-12

        .card.mb-4

          .card-header.d-flex.justify-content-between.align-items-center

            strong Event Occurrences

            .d-flex.gap-2

              button.btn.btn-primary(
                type='button'
                id='btnNewOccurrence'
              )
                i.fa.fa-plus.me-2
                | New Event Occurrence

          .card-body

            .row.mb-3

              .col-md-4

                input.form-control(
                  type='text'
                  id='searchOccurrence'
                  placeholder='Search Event Occurrences'
                )

            .table-responsive

              table.table.table-striped.table-hover

                thead

                  tr

                    th Event Name
                    th Event Type
                    th Event Area
                    th Organizer
                    th Sponsor
                    th Start Date
                    th End Date
                    th Start Time
                    th End Time
                    th Participants
                    th Status
                    th Actions

                tbody#occurrenceTableBody

            .row.mt-3

              .col-md-6

                small.text-muted#paginationInfo

              .col-md-6.text-end

                ul.pagination.justify-content-end.mb-0#paginationContainer

  .modal.fade(
    id='occurrenceModal'
    tabindex='-1'
    aria-hidden='true'
  )

    .modal-dialog.modal-xl

      .modal-content

        .modal-header

          h5.modal-title
            | Event Occurrence

          button.btn-close(
            type='button'
            data-coreui-dismiss='modal'
          )

        .modal-body

          input(
            type='hidden'
            id='eventInstanceId'
          )

          .card.mb-4

            .card-header

              strong Event Bundle

            .card-body

              .row

                .col-md-4.mb-3

                  label.form-label Event Name

                  select.form-select(
                    id='eventId'
                  )
                    option(value='')
                      | Select Event Name

                .col-md-4.mb-3

                  label.form-label Event Category

                  input.form-control(
                    id='eventCategory'
                    readonly
                  )

                .col-md-4.mb-3

                  label.form-label Event Type

                  input.form-control(
                    id='eventType'
                    readonly
                  )

          .card.mb-4

            .card-header

              strong Event Occurrence Details

            .card-body

              .row

                .col-md-6.mb-3

                  label.form-label Organizer

                  input.form-control(
                    id='organizer'
                    placeholder='Organizer'
                  )

                .col-md-6.mb-3

                  label.form-label Sponsor

                  select.form-select(
                    id='sponsorId'
                  )
                    option(value='')
                      | Select Sponsor

              .row

                .col-md-3.mb-3

                  label.form-label Country

                  select.form-select(
                    id='countryId'
                  )
                    option(value='')
                      | Select Country

                .col-md-3.mb-3

                  label.form-label County

                  select.form-select(
                    id='countyId'
                  )
                    option(value='')
                      | Select County

                .col-md-3.mb-3

                  label.form-label Subcounty

                  select.form-select(
                    id='subcountyId'
                  )
                    option(value='')
                      | Select Subcounty

                .col-md-3.mb-3

                  label.form-label Town

                  input.form-control(
                    id='townName'
                    list='townSuggestions'
                    placeholder='Type or Select Town'
                  )

                  datalist#townSuggestions

              .row

                .col-md-6.mb-3

                  label.form-label Event Area

                  input.form-control(
                    id='eventArea'
                    readonly
                  )

          .card.mb-4

            .card-header

              strong Event Schedule

            .card-body

              .row

                .col-md-3.mb-3

                  label.form-label Start Date

                  input.form-control(
                    type='date'
                    id='startDate'
                  )

                .col-md-3.mb-3

                  label.form-label End Date

                  input.form-control(
                    type='date'
                    id='endDate'
                  )

                .col-md-3.mb-3

                  label.form-label Start Time

                  input.form-control(
                    type='time'
                    id='startTime'
                  )

                .col-md-3.mb-3

                  label.form-label End Time

                  input.form-control(
                    type='time'
                    id='endTime'
                  )

          
          
          .card.mb-4(
            id='occurrenceStatusCard'
          )

            .card-header

              strong Event Status

            .card-body

              .row

                .col-md-4.mb-3

                  label.form-label Event Status

                  select.form-select(
                    id='occurrenceStatusId'
                  )

                    option(value='')
                      | Select Status

          .alert.alert-danger.d-none(
            id='occurrenceError'
          )

        .modal-footer

          button.btn.btn-secondary(
            type='button'
            data-coreui-dismiss='modal'
          )
            | Close

          button.btn.btn-primary(
            type='button'
            id='btnSaveOccurrence'
          )
            | Save Same

          button.btn.btn-success(
            type='button'
            id='btnSaveOccurrenceAsNew'
          )
            | Save New

append pageScripts

  script(src='js/events.js')