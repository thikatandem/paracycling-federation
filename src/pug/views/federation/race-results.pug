extends ../../_layout/default

block view

  .container-fluid

    .row

      .col-12

        .card.mb-4

          .card-header.d-flex.justify-content-between.align-items-center

            strong Race Results

            button.btn.btn-primary(
              type='button'
              id='btnAddResult'
            )
              i.fa.fa-plus.me-2
              | Add Result

          .card-body

            div.d-none.text-center.mb-3(
              id='resultLoading'
            )
              .spinner-border.text-primary

            .row.mb-3

              .col-md-4

                input.form-control(
                  type='text'
                  id='searchResult'
                  placeholder='Search Event, Team or Medal'
                )

            .table-responsive

              table.table.table-striped.table-hover

                thead

                  tr
                    th Event
                    th Team
                    th Position
                    th Finish Time
                    th Points
                    th Medal
                    th Actions

                tbody#resultsTableBody

            .row.mt-3

              .col-md-6

                button.btn.btn-secondary(
                  type='button'
                  id='btnRefreshResults'
                )
                  | Refresh

              .col-md-6.text-end

                button.btn.btn-outline-primary.me-2(
                  type='button'
                  id='btnPreviousPage'
                )
                  | Previous

                span#paginationInfo.mx-2
                  | Page 1

                button.btn.btn-outline-primary(
                  type='button'
                  id='btnNextPage'
                )
                  | Next

  .modal.fade(
    id='resultModal'
    tabindex='-1'
    aria-hidden='true'
  )

    .modal-dialog.modal-lg

      .modal-content

        .modal-header

          h5.modal-title
            | Race Result

          button.btn-close(
            type='button'
            data-coreui-dismiss='modal'
          )

        .modal-body

          input(
            type='hidden'
            id='resultId'
          )

          .row.g-3

            .col-md-6

              label.form-label Event

              select.form-select(
                id='eventId'
              )

            .col-md-6

              label.form-label Team

              select.form-select(
                id='teamId'
              )

                option(
                  value=''
                )
                  | Select Event First

            .col-md-4

              label.form-label Position

              input.form-control(
                type='number'
                min='1'
                id='position'
              )

            .col-md-4

              label.form-label Finish Time

              input.form-control(
                type='text'
                id='finishTime'
                placeholder='HH:MM:SS'
              )

            .col-md-4

              label.form-label Points

              input.form-control(
                type='number'
                min='0'
                id='points'
              )

            .col-md-12

              label.form-label Medal

              input.form-control(
                id='medal'
                readonly
              )

          .mt-3.text-danger(
            id='resultFormError'
          )

        .modal-footer

          button.btn.btn-secondary(
            type='button'
            data-coreui-dismiss='modal'
          )
            | Cancel

          button.btn.btn-success(
            type='button'
            id='btnSaveResult'
          )
            | Save Result

  .modal.fade(
    id='deleteResultModal'
    tabindex='-1'
    aria-hidden='true'
  )

    .modal-dialog

      .modal-content

        .modal-header

          h5.modal-title
            | Delete Result

          button.btn-close(
            type='button'
            data-coreui-dismiss='modal'
          )

        .modal-body

          p
            | Are you sure you want to delete this race result?

          input(
            type='hidden'
            id='deleteResultId'
          )

        .modal-footer

          button.btn.btn-secondary(
            type='button'
            data-coreui-dismiss='modal'
          )
            | Cancel

          button.btn.btn-danger(
            type='button'
            id='btnConfirmDeleteResult'
          )
            | Delete Result

append pageScripts

  script(src='js/race-results.js')