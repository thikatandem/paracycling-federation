extends ../../_layout/default

block view

  .container-fluid

    .row

      .col-12

        .card.mb-4

          .card-header.d-flex.justify-content-between.align-items-center

            strong Race Results

            button.btn.btn-primary(
              type='button'
              id='btnAddTraining'
            )
              i.fa.fa-plus.me-2
              | Add Result

          .card-body

            div.d-none.text-center.mb-3(
              id='trainingLoading'
            )
              .spinner-border.text-primary

            .row.mb-3

              .col-md-4

                input.form-control(
                  type='text'
                  id='searchTraining'
                  placeholder='Search Event, Program, Team or Session'
                )

            .table-responsive

              table.table.table-striped.table-hover

                thead

                  tr
                    th Date
                    th Type
                    th Athlete / Team
                    th Event
                    th Occurrence
                    th Program
                    th Status
                    th Position
                    th Points
                    th Medal
                    th Session
                    th Distance
                    th Duration
                    th Avg Speed
                    th Actions

                tbody#trainingTableBody

            .row.mt-3

              .col-md-6

                button.btn.btn-secondary(
                  type='button'
                  id='btnRefreshTraining'
                )
                  | Refresh

              .col-md-6.text-end

                button.btn.btn-outline-primary.me-2(
                  type='button'
                  id='btnPreviousPage'
                )
                  | Previous

                span#paginationInfo.mx-2
                  | Page 1

                button.btn.btn-outline-primary(
                  type='button'
                  id='btnNextPage'
                )
                  | Next

  .modal.fade(
    id='competitionResultModal'
    tabindex='-1'
    aria-hidden='true'
  )

    .modal-dialog.modal-xl

      .modal-content

        .modal-header

          h5.modal-title
            | Race Results

          button.btn-close(
            type='button'
            data-coreui-dismiss='modal'
          )

        .modal-body

          input(
            type='hidden'
            id='resultId'
          )

          .row.g-3

            .col-md-4

              label.form-label Competition Event

              select.form-select(
                id='eventId'
              )

            .col-md-4

              label.form-label Event Occurrence

              select.form-select(
                id='eventInstanceId'
              )

                option(value='')
                  | Select Occurrence

            .col-md-12

              label.form-label Competition Participants

              .mt-2.competition-group-options

                .form-check.form-check-inline

                  input.form-check-input(
                    type='radio'
                    name='competitionType'
                    id='competitionTypeIndividual'
                    value='INDIVIDUAL'
                  )

                  label.form-check-label(
                    for='competitionTypeIndividual'
                  )
                    | Individual

                .form-check.form-check-inline

                  input.form-check-input(
                    type='radio'
                    name='competitionType'
                    id='competitionTypeTeam'
                    value='TEAM'
                    checked
                  )

                  label.form-check-label(
                    for='competitionTypeTeam'
                  )
                    | Team

            .col-md-4

              label.form-label Program

              select.form-select(
                id='programId'
              )

                option(value='')
                  | Select Program

            .col-md-4

              label.form-label Participant

              select.form-select(
                id='participantId'
              )

                option(value='')
                  | Select Participant

            .col-md-4

              label.form-label Participant Status

              select.form-select(
                id='participantStatusId'
              )

                option(value='')
                  | Select Status

            .col-md-3

              label.form-label Competition Date

              input.form-control(
                type='date'
                id='competitionDate'
              )

            .col-md-3

              label.form-label Competition Week

              input.form-control(
                type='text'
                id='competitionWeek'
              )

            .col-md-3

              label.form-label Competition Day

              input.form-control(
                type='text'
                id='competitionDay'
              )

            .col-md-3

              label.form-label County

              select.form-select(
                id='countyId'
                disabled
              )

                option(value='')
                  | Select County

            .col-md-3

              label.form-label Subcounty

              select.form-select(
                id='subcountyId'
                disabled
              )

                option(value='')
                  | Select Subcounty

            .col-md-3

              label.form-label Town

              input.form-control(
                id='townName'
                readonly
              )

            .col-md-3

              label.form-label Session Type

              input.form-control(
                id='sessionType'
                readonly
              )

            .col-md-3

              label.form-label Start Time

              input.form-control(
                type='time'
                id='startTime'
              )

            .col-md-3

              label.form-label End Time

              input.form-control(
                type='time'
                id='endTime'
              )

            .col-md-3

              label.form-label Duration (Minutes)

              input.form-control(
                type='number'
                id='durationMinutes'
                readonly
              )

            .col-md-3

              label.form-label Position

              input.form-control(
                type='number'
                id='position'
                min='1'
              )

            .col-md-3

              label.form-label Points

              input.form-control(
                type='number'
                id='points'
              )

            .col-md-3

              label.form-label Medal

              input.form-control(
                id='medal'
                readonly
              )

            .col-md-3

              label.form-label Max Speed

              input.form-control(
                type='number'
                step='0.01'
                id='maxSpeedKmh'
              )

            .col-md-3

              label.form-label Distance (KM)

              input.form-control(
                type='number'
                step='0.01'
                id='distanceKm'
              )

            .col-md-4

              label.form-label Average Speed

              input.form-control(
                type='number'
                id='avgSpeedKmh'
                readonly
              )

            .col-md-4

              label.form-label Indoor Session

              select.form-select(
                id='indoorSession'
              )

                option(value='false') No
                option(value='true') Yes

            .col-md-4

              label.form-label Attendance

              select.form-select(
                id='attendance'
              )

                option(value='true') Present
                option(value='false') Absent

            .col-md-12

              label.form-label Notes

              textarea.form-control(
                rows='3'
                id='notes'
              )

          .mt-3

            .alert.alert-danger.d-none(
              id='trainingFormError'
            )

            .alert.alert-success.d-none(
              id='trainingFormSuccess'
            )

        .modal-footer

          button.btn.btn-secondary(
            type='button'
            data-coreui-dismiss='modal'
          )
            | Cancel

          button.btn.btn-success(
            type='button'
            id='btnsaveCompetitionResult'
          )
            | Save Result

  .modal.fade(
    id='deleteCompetitionResultModal'
    tabindex='-1'
    aria-hidden='true'
  )

    .modal-dialog

      .modal-content

        .modal-header

          h5.modal-title
            | Delete Race Result

          button.btn-close(
            type='button'
            data-coreui-dismiss='modal'
          )

        .modal-body

          p
            | Are you sure you want to delete this race result?

          input(
            type='hidden'
            id='deleteresultId'
          )

        .modal-footer

          button.btn.btn-secondary(
            type='button'
            data-coreui-dismiss='modal'
          )
            | Cancel

          button.btn.btn-danger(
            type='button'
            id='btnConfirmdeleteCompetitionResult'
          )
            | Delete Competition Result

append pageScripts

  script(src='js/race-results.js')