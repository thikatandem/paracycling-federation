extends ../../_layout/default

block view

  .container-fluid

    .row

      .col-12

        .card.mb-4

          .card-header.d-flex.justify-content-between.align-items-center

            .d-flex.flex-column

              strong Event Report

              small.text-muted
                | Event Intelligence Center

            .d-flex.gap-2

              button.btn.btn-secondary(
                type='button'
                id='btnRefreshEventReport'
              )
                i.fa.fa-refresh.me-2
                | Refresh

              button.btn.btn-success(
                type='button'
                id='btnExportEventReportCsv'
              )
                i.fa.fa-file-excel-o.me-2
                | Export CSV

              button.btn.btn-primary(
                type='button'
                id='btnExportEventReportExcel'
              )
                i.fa.fa-table.me-2
                | Export Excel

              button.btn.btn-dark(
                type='button'
                id='btnPrintEventReport'
              )
                i.fa.fa-print.me-2
                | Print

          .card-body

            div.d-none.text-center.mb-3(
              id='eventReportLoading'
            )
              .spinner-border.text-primary

            // =====================================================
            // FILTERS
            // =====================================================

            .row.g-3.mb-4

              .col-md-4

                label.form-label Search

                input.form-control(
                  type='text'
                  id='searchEventReport'
                  placeholder='Search Event, Organizer, County, Sponsor...'
                )

              .col-md-2

                label.form-label Status

                select.form-select(
                  id='filterEventStatus'
                )
                  option(value='')
                    | All Statuses

              .col-md-2

                label.form-label Category

                select.form-select(
                  id='filterEventCategory'
                )
                  option(value='')
                    | All Categories

              .col-md-2

                label.form-label County

                select.form-select(
                  id='filterEventCounty'
                )
                  option(value='')
                    | All Counties

              .col-md-2

                label.form-label Year

                select.form-select(
                  id='filterEventYear'
                )
                  option(value='')
                    | All Years

            // =====================================================
            // SUMMARY CARDS
            // =====================================================

            .row.g-3.mb-4

              .col-md-2

                .card.border-primary

                  .card-body.text-center

                    h6.text-muted.mb-2
                      | Total Events

                    h3.mb-0(
                      id='totalEventsCard'
                    )
                      | 0

              .col-md-2

                .card.border-info

                  .card-body.text-center

                    h6.text-muted.mb-2
                      | Upcoming

                    h3.mb-0(
                      id='upcomingEventsCard'
                    )
                      | 0

              .col-md-2

                .card.border-success

                  .card-body.text-center

                    h6.text-muted.mb-2
                      | Ongoing

                    h3.mb-0(
                      id='ongoingEventsCard'
                    )
                      | 0

              .col-md-2

                .card.border-secondary

                  .card-body.text-center

                    h6.text-muted.mb-2
                      | Completed

                    h3.mb-0(
                      id='completedEventsCard'
                    )
                      | 0

              .col-md-2

                .card.border-danger

                  .card-body.text-center

                    h6.text-muted.mb-2
                      | Cancelled

                    h3.mb-0(
                      id='cancelledEventsCard'
                    )
                      | 0

              .col-md-1

                .card.border-warning

                  .card-body.text-center

                    h6.text-muted.mb-2
                      | Competition

                    h3.mb-0(
                      id='competitionEventsCard'
                    )
                      | 0

              .col-md-1

                .card.border-dark

                  .card-body.text-center

                    h6.text-muted.mb-2
                      | Training

                    h3.mb-0(
                      id='trainingEventsCard'
                    )
                      | 0

            // =====================================================
            // STATUS ANALYSIS
            // =====================================================

            .card.mb-4

              .card-header

                h5.mb-0
                  | Status Analysis

              .card-body

                .table-responsive

                  table.table.table-striped.table-bordered

                    thead

                      tr

                        th Status

                        th Count

                        th Percentage

                    tbody(
                      id='eventStatusAnalysisBody'
                    )

            // =====================================================
            // CATEGORY ANALYSIS
            // =====================================================

            .card.mb-4

              .card-header

                h5.mb-0
                  | Category Analysis

              .card-body

                .table-responsive

                  table.table.table-striped.table-bordered

                    thead

                      tr

                        th Category

                        th Count

                        th Percentage

                    tbody(
                      id='eventCategoryAnalysisBody'
                    )

            // =====================================================
            // COUNTY ANALYSIS
            // =====================================================

            .card.mb-4

              .card-header

                h5.mb-0
                  | County Analysis

              .card-body

                .table-responsive

                  table.table.table-striped.table-bordered

                    thead

                      tr

                        th County

                        th Events

                        th Teams

                        th Participants

                    tbody(
                      id='eventCountyAnalysisBody'
                    )

            // =====================================================
            // SPONSOR ANALYSIS
            // =====================================================

            .card.mb-4

              .card-header

                h5.mb-0
                  | Sponsor Analysis

              .card-body

                .table-responsive

                  table.table.table-striped.table-bordered

                    thead

                      tr

                        th Sponsor

                        th Events Sponsored

                    tbody(
                      id='eventSponsorAnalysisBody'
                    )

            // =====================================================
            // EVENT INTELLIGENCE GRID
            // =====================================================

            .card

              .card-header

                h5.mb-0
                  | Event Intelligence

              .card-body

                .table-responsive

                  table.table.table-striped.table-hover.table-bordered

                    thead

                      tr

                        th.sortable(
                          data-sort='event_code'
                        )
                          | Event Code

                        th.sortable(
                          data-sort='event_name'
                        )
                          | Event Name

                        th.sortable(
                          data-sort='category'
                        )
                          | Category

                        th.sortable(
                          data-sort='county'
                        )
                          | County

                        th.sortable(
                          data-sort='organizer'
                        )
                          | Organizer

                        th.sortable(
                          data-sort='start_date'
                        )
                          | Start Date

                        th.sortable(
                          data-sort='end_date'
                        )
                          | End Date

                        th.sortable(
                          data-sort='duration'
                        )
                          | Duration

                        th
                          | Teams

                        th
                          | Participants

                        th.sortable(
                          data-sort='status'
                        )
                          | Status

                        th
                          | Actions

                    tbody(
                      id='eventReportTableBody'
                    )

            // =====================================================
            // PAGINATION
            // =====================================================

            .row.mt-3

              .col-md-6

                span(
                  id='eventReportPaginationInfo'
                )
                  | Page 1

              .col-md-6.text-end

                button.btn.btn-outline-primary.me-2(
                  type='button'
                  id='btnPreviousEventReportPage'
                )
                  | Previous

                button.btn.btn-outline-primary(
                  type='button'
                  id='btnNextEventReportPage'
                )
                  | Next

  // =====================================================
  // EVENT INTELLIGENCE MODAL
  // =====================================================

  .modal.fade(
    id='eventIntelligenceModal'
    tabindex='-1'
    aria-hidden='true'
  )

    .modal-dialog.modal-xl

      .modal-content

        .modal-header

          h5.modal-title
            | Event Intelligence

          button.btn-close(
            type='button'
            data-coreui-dismiss='modal'
          )

        .modal-body

          .row.mb-4

            .col-md-3

              .card

                .card-body

                  h6.text-muted
                    | Event Name

                  div(
                    id='reportEventName'
                  )

            .col-md-3

              .card

                .card-body

                  h6.text-muted
                    | Category

                  div(
                    id='reportEventCategory'
                  )

            .col-md-3

              .card

                .card-body

                  h6.text-muted
                    | Status

                  div(
                    id='reportEventStatus'
                  )

            .col-md-3

              .card

                .card-body

                  h6.text-muted
                    | Duration

                  div(
                    id='reportEventDuration'
                  )

          .row.mb-4

            .col-md-3

              .card

                .card-body

                  h6.text-muted
                    | Country

                  div(
                    id='reportEventCountry'
                  )

            .col-md-3

              .card

                .card-body

                  h6.text-muted
                    | County

                  div(
                    id='reportEventCounty'
                  )

            .col-md-3

              .card

                .card-body

                  h6.text-muted
                    | Town

                  div(
                    id='reportEventTown'
                  )

            .col-md-3

              .card

                .card-body

                  h6.text-muted
                    | Organizer

                  div(
                    id='reportEventOrganizer'
                  )

          h5.mb-3
            | Participation Statistics

          .table-responsive.mb-4

            table.table.table-striped.table-bordered

              tbody

                tr

                  th Registered Teams

                  td(
                    id='reportRegisteredTeams'
                  )

                tr

                  th Registered Participants

                  td(
                    id='reportRegisteredParticipants'
                  )

                tr

                  th Programs

                  td(
                    id='reportPrograms'
                  )

                tr

                  th Sponsors

                  td(
                    id='reportSponsors'
                  )

          h5.mb-3
            | Performance Statistics

          .table-responsive

            table.table.table-striped.table-bordered

              tbody

                tr

                  th Results Recorded

                  td(
                    id='reportResultsRecorded'
                  )

                tr

                  th Rankings Generated

                  td(
                    id='reportRankingsGenerated'
                  )

                tr

                  th Performance Records

                  td(
                    id='reportPerformanceRecords'
                  )

        .modal-footer

          button.btn.btn-secondary(
            type='button'
            data-coreui-dismiss='modal'
          )
            | Close

append pageScripts

  script(
    src='js/event-report.js'
  )