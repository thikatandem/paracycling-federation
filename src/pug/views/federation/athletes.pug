extends ../../_layout/default

block view

  .container-fluid

    .row
      .col-12

        .card.mb-4

          .card-header.d-flex.justify-content-between.align-items-center

            strong Athletes

            button.btn.btn-primary(
              type='button'
              id='btnAddAthlete'
            )
              i.fa.fa-plus.me-2
              | Add Athlete

          .card-body

            div.d-none.text-center.mb-3(
              id='athleteLoading'
            )
              .spinner-border.text-primary

            .row.mb-3

              .col-md-4
                input.form-control(
                  type='text'
                  id='searchAthlete'
                  placeholder='Search Athletes'
                )

            .table-responsive

              table.table.table-striped.table-hover

                thead

                  tr
                    th Athlete Code
                    th First Name
                    th Last Name
                    th Gender
                    th Role
                    th County
                    th Phone
                    th Status
                    th Actions

                tbody#athletesTableBody

            .row.mt-3

              .col-md-6

                button.btn.btn-secondary(
                  type='button'
                  id='btnRefreshAthletes'
                )
                  | Refresh

              .col-md-6.text-end

                button.btn.btn-outline-primary.me-2(
                  type='button'
                  id='btnPreviousPage'
                )
                  | Previous

                span#paginationInfo.mx-2
                  | Page 1

                button.btn.btn-outline-primary(
                  type='button'
                  id='btnNextPage'
                )
                  | Next

  .modal.fade(
    id='athleteModal'
    tabindex='-1'
    aria-hidden='true'
  )

    .modal-dialog.modal-xl

      .modal-content

        .modal-header

          h5.modal-title#athleteModalTitle
            | Athlete

          button.btn-close(
            type='button'
            data-coreui-dismiss='modal'
          )

        .modal-body

          input(
            type='hidden'
            id='athleteId'
          )

          .row.g-3

            .col-md-3
              label.form-label Athlete Code
              input.form-control(
                id='athleteCode'
                readonly
              )

            .col-md-3
              label.form-label First Name
              input.form-control(
                id='firstName'
              )

            .col-md-3
              label.form-label Last Name
              input.form-control(
                id='lastName'
              )

            .col-md-3
              label.form-label Date Of Birth
              input.form-control(
                type='date'
                id='dob'
              )

            .col-md-3
              label.form-label Gender
              select.form-select(
                id='gender'
              )
                option(value='')
                option(value='Male') Male
                option(value='Female') Female

            .col-md-3
              label.form-label Role
              select.form-select(
                id='role'
              )
                option(value='')
                option(value='Pilot') Pilot
                option(value='Stoker') Stoker
                option(value='Coach') Coach
                option(value='Support Staff') Support Staff

            .col-md-3
              label.form-label Classification
              select.form-select(
                id='classificationId'
              )

            .col-md-3
              label.form-label County
              select.form-select(
                id='countyId'
              )

            .col-md-4
              label.form-label Passport No
              input.form-control(
                id='passportNo'
              )

            .col-md-4
              label.form-label National ID
              input.form-control(
                id='nationalId'
              )

            .col-md-4
              label.form-label Phone
              input.form-control(
                id='phone'
              )

            .col-md-4
              label.form-label Email
              input.form-control(
                type='email'
                id='email'
              )

            .col-md-4
              label.form-label Emergency Contact Name
              input.form-control(
                id='emergencyContactName'
              )

            .col-md-4
              label.form-label Emergency Contact Phone
              input.form-control(
                id='emergencyContactPhone'
              )

            .col-md-4
              label.form-label Registration Date
              input.form-control(
                type='date'
                id='registrationDate'
                readonly
              )

            .col-md-4
              label.form-label Status
              select.form-select(
                id='status'
              )
                option(value='Active' selected) Active
                option(value='Inactive') Inactive
                option(value='Disabled') Disabled

          .mt-3.text-danger(
            id='athleteFormError'
          )

        .modal-footer

          button.btn.btn-secondary(
            type='button'
            data-coreui-dismiss='modal'
          )
            | Cancel

          button.btn.btn-success(
            type='button'
            id='btnSaveAthlete'
          )
            | Save Athlete

  .modal.fade(
    id='deleteAthleteModal'
    tabindex='-1'
    aria-hidden='true'
  )

    .modal-dialog

      .modal-content

        .modal-header

          h5.modal-title
            | Delete Athlete

          button.btn-close(
            type='button'
            data-coreui-dismiss='modal'
          )

        .modal-body

          p
            | Are you sure you want to delete this athlete?

          input(
            type='hidden'
            id='deleteAthleteId'
          )

        .modal-footer

          button.btn.btn-secondary(
            type='button'
            data-coreui-dismiss='modal'
          )
            | Cancel

          button.btn.btn-danger(
            type='button'
            id='btnConfirmDeleteAthlete'
          )
            | Delete Athlete

append pageScripts
  script(src='js/athletes.js')